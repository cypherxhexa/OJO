# ─── Environment Variables ────────────────────────────────────────────────────
# Copy this to .env and fill in your values before running locally.

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (for prisma migrate dev)
DATABASE_URL="file:./dev.db"

# Turso (LibSQL) — your production database
TURSO_DATABASE_URL="libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Site ──────────────────────────────────────────────────────────────────────
# Public base URL — used in sitemaps, canonical tags, and OG URLs
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD="change-me-to-a-strong-password"

# ── Contact ───────────────────────────────────────────────────────────────────
# Displayed on the Contact page and legal pages
CONTACT_EMAIL="contact@yourdomain.com"

# ── Google AdSense ────────────────────────────────────────────────────────────
# Leave blank during development — placeholder ad boxes will appear instead.
# After AdSense approval, paste your publisher ID and slot IDs below.
# Then add these same values to Vercel → Project → Settings → Environment Variables.
# A full redeploy is required after updating env vars on Vercel.

# Your AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Homepage: leaderboard banner below hero, above job grid (Slot 1 of 2)
NEXT_PUBLIC_ADSENSE_SLOT_HOME_BANNER=XXXXXXXXXX

# Homepage: in-feed native unit after every 8 job cards (Slot 2 of 2)
NEXT_PUBLIC_ADSENSE_SLOT_HOME_INFEED=XXXXXXXXXX

# Job detail page: rectangle in right sidebar below job summary (Slot 1 of 2)
NEXT_PUBLIC_ADSENSE_SLOT_JOB_SIDEBAR=XXXXXXXXXX

# Job detail page: leaderboard at bottom of page above footer (Slot 2 of 2)
NEXT_PUBLIC_ADSENSE_SLOT_JOB_BOTTOM=XXXXXXXXXX

# Redirect/interstitial page: rectangle centered in content card (Slot 1 of 1 — MAX)
NEXT_PUBLIC_ADSENSE_SLOT_REDIRECT=XXXXXXXXXX

# Blog post page: leaderboard below title/meta, above first paragraph (Slot 1 of 3)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_TOP=XXXXXXXXXX

# Blog post page: rectangle injected after 3rd paragraph (Slot 2 of 3)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_MID=XXXXXXXXXX

# Blog post page: leaderboard above Related Posts section (Slot 3 of 3 — MAX)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_BOTTOM=XXXXXXXXXX

# Blog listing page: leaderboard below page heading, above post grid (Slot 1 of 1 — MAX)
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=XXXXXXXXXX
